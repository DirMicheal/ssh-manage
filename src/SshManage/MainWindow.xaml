<Window x:Class="SshManage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SshManage.Views"
        xmlns:helpers="clr-namespace:SshManage.Helpers"
        Title="SSH配置管理器" 
        Height="650" 
        Width="1000"
        MinWidth="800"
        MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel>
                <Border Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                        <Border Width="36" Height="36" Background="{StaticResource PrimaryBrush}" CornerRadius="8" HorizontalAlignment="Center">
                            <TextBlock Text="🔐" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SSH管理器" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="v2.0.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListBox x:Name="NavListBox" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Margin="0,8,0,0"
                         SelectionChanged="NavListBox_SelectionChanged">
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="SiteManage">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="🌐" FontSize="18" />
                            <TextBlock Text="站点管理" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="KeyManage">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="🔑" FontSize="18" />
                            <TextBlock Text="密钥管理" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="AgentManage">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="🛡️" FontSize="18" />
                            <TextBlock Text="代理管控" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="PermissionFix">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="🔧" FontSize="18" />
                            <TextBlock Text="权限修复" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="ConnectionTest">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="📶" FontSize="18" />
                            <TextBlock Text="连通性检测" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="TemplateManage">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="📋" FontSize="18" />
                            <TextBlock Text="站点模板" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="BackupManage">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="💿" FontSize="18" />
                            <TextBlock Text="配置备份" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="Migration">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="📦" FontSize="18" />
                            <TextBlock Text="配置迁移" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="GitHubFix">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="🐙" FontSize="18" />
                            <TextBlock Text="GitHub修复" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource SidebarItemStyle}" Tag="ConfigEditor">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="10">
                            <TextBlock Text="📝" FontSize="18" />
                            <TextBlock Text="配置编辑" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <Border Margin="8" Padding="12" Background="#FFF9F0" CornerRadius="6" Visibility="Visible">
                    <StackPanel helpers:StackPanelHelper.Spacing="6">
                        <TextBlock Text="💡 小提示" FontSize="12" FontWeight="SemiBold" Foreground="#B7791F" />
                        <TextBlock Text="Windows OpenSSH 私钥权限过大会导致连接失败，可使用权限修复一键解决。" 
                                   FontSize="11" 
                                   TextWrapping="Wrap" 
                                   Foreground="#8A6118" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
        </Border>
    </Grid>
</Window>
