<Page x:Class="SshManage.Views.TemplateManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:helpers="clr-namespace:SshManage.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="站点模板">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
            <TextBlock Text="站点模板" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="保存站点配置为模板，快速创建新站点" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,16">
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <Button x:Name="BtnSaveAsTemplate" Content="💾 从站点保存为模板" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSaveAsTemplate_Click" />
                <Button x:Name="BtnCreateTemplate" Content="➕ 新建模板" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCreateTemplate_Click" />
                <Button x:Name="BtnDeleteTemplate" Content="🗑️ 删除模板" Style="{StaticResource SecondaryButtonStyle}" Click="BtnDeleteTemplate_Click" IsEnabled="False" />
                <Button x:Name="BtnApplyTemplate" Content="📋 应用模板创建站点" Style="{StaticResource PrimaryButtonStyle}" Click="BtnApplyTemplate_Click" IsEnabled="False" />
                <Button x:Name="BtnRefresh" Content="🔄 刷新" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRefresh_Click" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 模板列表" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
                <ListView x:Name="TemplateListView"
                          Grid.Row="1"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionChanged="TemplateListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="150" />
                            <GridViewColumn Header="描述" DisplayMemberBinding="{Binding Description}" Width="200" />
                            <GridViewColumn Header="地址" DisplayMemberBinding="{Binding HostName}" Width="130" />
                            <GridViewColumn Header="端口" DisplayMemberBinding="{Binding Port}" Width="60" />
                            <GridViewColumn Header="用户" DisplayMemberBinding="{Binding User}" Width="100" />
                            <GridViewColumn Header="分组" DisplayMemberBinding="{Binding GroupName}" Width="100" />
                            <GridViewColumn Header="创建时间" DisplayMemberBinding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <StackPanel helpers:StackPanelHelper.Spacing="8">
                <TextBlock Text="🔍 模板详情预览" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                <Grid x:Name="DetailPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="名称" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailName" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Text="地址" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailHostName" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0">
                        <TextBlock Text="端口" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailPort" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="用户" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailUser" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Text="分组" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailGroup" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,0,0">
                        <TextBlock Text="创建时间" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailCreatedAt" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                        <TextBlock Text="描述" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="DetailDescription" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="DetailEmptyHint" Text="选择模板查看详情" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
