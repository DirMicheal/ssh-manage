<Page x:Class="SshManage.Views.KeyManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:helpers="clr-namespace:SshManage.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="密钥管理">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
            <TextBlock Text="密钥管理" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="管理SSH公私钥，一键生成与复制公钥" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,16">
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <Button x:Name="BtnGenerateKey" Content="➕ 生成新密钥" Style="{StaticResource PrimaryButtonStyle}" Click="BtnGenerateKey_Click" />
                <Button x:Name="BtnCopyPublicKey" Content="📋 复制公钥" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCopyPublicKey_Click" IsEnabled="False" />
                <Button x:Name="BtnFixPermission" Content="🔧 修复权限" Style="{StaticResource SecondaryButtonStyle}" Click="BtnFixPermission_Click" IsEnabled="False" />
                <Button x:Name="BtnDeleteKey" Content="🗑️ 删除密钥" Style="{StaticResource SecondaryButtonStyle}" Click="BtnDeleteKey_Click" IsEnabled="False" />
                <Button x:Name="BtnRefresh" Content="🔄 刷新" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRefresh_Click" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 密钥列表" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
                <ListView x:Name="KeyListView" 
                          Grid.Row="1" 
                          BorderThickness="0" 
                          Background="Transparent"
                          SelectionChanged="KeyListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="状态" Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="14" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="150" />
                            <GridViewColumn Header="类型" DisplayMemberBinding="{Binding Type}" Width="80" />
                            <GridViewColumn Header="私钥" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HasPrivateKey, Converter={StaticResource BoolToIconConverter}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="公钥" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HasPublicKey, Converter={StaticResource BoolToIconConverter}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="权限状态" DisplayMemberBinding="{Binding PermissionStatus}" Width="100" />
                            <GridViewColumn Header="指纹" DisplayMemberBinding="{Binding Fingerprint}" Width="250" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <StackPanel helpers:StackPanelHelper.Spacing="8">
                <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                    <TextBlock Text="📝 密钥详情" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock x:Name="MichealKeyBadge" Text="⭐ Micheal私钥" FontSize="12" FontWeight="SemiBold" Foreground="#B7791F" Visibility="Collapsed" VerticalAlignment="Center" />
                </StackPanel>
                <DockPanel>
                    <TextBlock Text="私钥路径:" Width="80" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox x:Name="PrivateKeyPathTextBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12" />
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="公钥内容:" Width="80" VerticalAlignment="Top" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                    <TextBox x:Name="PublicKeyPreviewTextBox" 
                             Height="80" 
                             TextWrapping="Wrap" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12" />
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
