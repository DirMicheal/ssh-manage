<Window x:Class="SshManage.Views.GenerateKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:SshManage.Helpers"
        Title="生成密钥" 
        Height="450" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="生成SSH密钥" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" helpers:StackPanelHelper.Spacing="12">
            <GroupBox Header="密钥设置" Padding="12">
                <StackPanel helpers:StackPanelHelper.Spacing="10">
                    <DockPanel>
                        <TextBlock Text="密钥名称" Width="100" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox x:Name="KeyNameTextBox" Text="id_rsa" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="密钥类型" Width="100" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <ComboBox x:Name="KeyTypeComboBox" Width="150" HorizontalAlignment="Left" SelectionChanged="KeyTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="RSA" Tag="RSA" IsSelected="True" />
                            <ComboBoxItem Content="ECDSA" Tag="ECDSA" />
                            <ComboBoxItem Content="Ed25519" Tag="Ed25519" />
                            <ComboBoxItem Content="DSA" Tag="DSA" />
                        </ComboBox>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="密钥长度" Width="100" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <ComboBox x:Name="KeySizeComboBox" Width="150" HorizontalAlignment="Left">
                            <ComboBoxItem Content="1024" Tag="1024" />
                            <ComboBoxItem Content="2048" Tag="2048" IsSelected="True" />
                            <ComboBoxItem Content="4096" Tag="4096" />
                        </ComboBox>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="注释" Width="100" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox x:Name="CommentTextBox" />
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="安全设置" Padding="12">
                <StackPanel helpers:StackPanelHelper.Spacing="10">
                    <DockPanel>
                        <TextBlock Text="密码短语" Width="100" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <PasswordBox x:Name="PassphraseBox" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="确认密码" Width="100" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <PasswordBox x:Name="ConfirmPassphraseBox" />
                    </DockPanel>
                    <TextBlock Text="提示：密码短语为空时，密钥将无密码保护" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="100" Click="BtnCancel_Click" />
            <Button x:Name="BtnGenerate" Content="生成" Style="{StaticResource PrimaryButtonStyle}" Width="100" Click="BtnGenerate_Click" />
        </StackPanel>
    </Grid>
</Window>
