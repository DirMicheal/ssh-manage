<Page x:Class="SshManage.Views.BackupManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:helpers="clr-namespace:SshManage.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="配置备份管理">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
            <TextBlock Text="配置备份管理" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="管理SSH配置文件备份，一键恢复历史配置" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,16">
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <Button x:Name="BtnCreateBackup" Content="💾 创建备份" Style="{StaticResource PrimaryButtonStyle}" Click="BtnCreateBackup_Click" />
                <Button x:Name="BtnRestore" Content="🔄 恢复备份" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRestore_Click" IsEnabled="False" />
                <Button x:Name="BtnDeleteBackup" Content="🗑️ 删除备份" Style="{StaticResource SecondaryButtonStyle}" Click="BtnDeleteBackup_Click" IsEnabled="False" />
                <Button x:Name="BtnRefresh" Content="🔄 刷新" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRefresh_Click" />
                <Button x:Name="BtnCleanup" Content="🧹 清理旧备份" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCleanup_Click" />
            </StackPanel>
        </Border>

        <TextBlock x:Name="StatusText" Grid.Row="2" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />

        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 备份列表" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
                <ListView x:Name="BackupListView" 
                          Grid.Row="1" 
                          BorderThickness="0" 
                          Background="Transparent"
                          MouseDoubleClick="BackupListView_MouseDoubleClick"
                          SelectionChanged="BackupListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="类型" DisplayMemberBinding="{Binding DisplayType}" Width="100" />
                            <GridViewColumn Header="时间" DisplayMemberBinding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                            <GridViewColumn Header="大小" DisplayMemberBinding="{Binding DisplaySize}" Width="80" />
                            <GridViewColumn Header="站点数" DisplayMemberBinding="{Binding SiteCount}" Width="60" />
                            <GridViewColumn Header="描述" DisplayMemberBinding="{Binding Description}" Width="300" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <StackPanel helpers:StackPanelHelper.Spacing="8">
                <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                    <TextBlock Text="📂 备份目录" FontWeight="SemiBold" FontSize="14" />
                </StackPanel>
                <DockPanel>
                    <TextBlock Text="路径:" Width="50" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox x:Name="BackupPathTextBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12" />
                </DockPanel>
                <TextBlock Text="💡 提示：恢复备份前会自动创建当前配置的备份，防止误操作导致配置丢失" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
