<Page x:Class="SshManage.Views.MigrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:helpers="clr-namespace:SshManage.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="配置迁移">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
            <TextBlock Text="配置迁移" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="导入导出SSH站点配置，支持JSON和OpenSSH格式" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <TextBlock Text="📤 导出配置" FontWeight="SemiBold" FontSize="14" />
                    <DockPanel>
                        <TextBlock Text="导出格式:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" />
                        <ComboBox x:Name="ExportFormatComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="JSON" />
                            <ComboBoxItem Content="OpenSSH Config" />
                        </ComboBox>
                    </DockPanel>
                    <Button x:Name="BtnExport" Content="导出配置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Click="BtnExport_Click" />
                    <TextBlock Text="将当前所有站点配置导出为文件" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <TextBlock Text="📥 导入配置" FontWeight="SemiBold" FontSize="14" />
                    <DockPanel>
                        <TextBlock Text="导入格式:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" />
                        <ComboBox x:Name="ImportFormatComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="JSON" />
                            <ComboBoxItem Content="OpenSSH Config" />
                        </ComboBox>
                    </DockPanel>
                    <Button x:Name="BtnImport" Content="导入配置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Click="BtnImport_Click" />
                    <TextBlock Text="⚠️ 导入将覆盖同名站点配置，请谨慎操作" FontSize="12" Foreground="{StaticResource WarningBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="📋 导入预览" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                    <Button x:Name="BtnMerge" Content="🔗 合并到现有配置" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Click="BtnMerge_Click" IsEnabled="False" />
                </DockPanel>
                <ListView x:Name="ImportPreviewListView"
                          Grid.Row="1"
                          BorderThickness="0"
                          Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Host" DisplayMemberBinding="{Binding Host}" Width="150" />
                            <GridViewColumn Header="HostName" DisplayMemberBinding="{Binding HostName}" Width="150" />
                            <GridViewColumn Header="Port" DisplayMemberBinding="{Binding Port}" Width="60" />
                            <GridViewColumn Header="User" DisplayMemberBinding="{Binding User}" Width="100" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <TextBlock x:Name="StatusText" Grid.Row="3" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
    </Grid>
</Page>
