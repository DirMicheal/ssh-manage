<Window x:Class="SshManage.Views.SiteEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:SshManage.Helpers"
        Title="编辑站点" 
        Height="650" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel helpers:StackPanelHelper.Spacing="12">
                <GroupBox Header="基本信息" Padding="12">
                    <StackPanel helpers:StackPanelHelper.Spacing="10">
                        <DockPanel>
                            <TextBlock Text="主机名 (Host)" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="HostTextBox" />
                        </DockPanel>
                        <TextBlock x:Name="HostWarningText" Text="" FontSize="11" Foreground="{StaticResource ErrorBrush}" Margin="120,0,0,0" Visibility="Collapsed" />
                        <DockPanel>
                            <TextBlock Text="服务器地址" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="HostNameTextBox" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="端口" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="PortTextBox" Text="22" Width="100" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="用户名" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="UserTextBox" />
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="认证设置" Padding="12">
                    <StackPanel helpers:StackPanelHelper.Spacing="10">
                        <DockPanel>
                            <TextBlock Text="私钥文件" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <DockPanel>
                                <Button x:Name="BtnBrowseKey" Content="浏览..." Width="80" DockPanel.Dock="Right" Style="{StaticResource SecondaryButtonStyle}" Click="BtnBrowseKey_Click" />
                                <TextBox x:Name="IdentityFileTextBox" />
                            </DockPanel>
                        </DockPanel>
                        <CheckBox x:Name="ForwardAgentCheckBox" Content="启用 SSH Agent 转发 (ForwardAgent)" Margin="120,0,0,0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="代理设置" Padding="12">
                    <StackPanel helpers:StackPanelHelper.Spacing="10">
                        <DockPanel>
                            <TextBlock Text="ProxyCommand" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="ProxyCommandTextBox" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="ProxyJump" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="ProxyJumpTextBox" />
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="连接设置" Padding="12">
                    <StackPanel helpers:StackPanelHelper.Spacing="10">
                        <DockPanel>
                            <TextBlock Text="心跳间隔(秒)" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="ServerAliveIntervalTextBox" Text="0" Width="100" HorizontalAlignment="Left" />
                        </DockPanel>
                        <CheckBox x:Name="CompressionCheckBox" Content="启用压缩 (Compression)" Margin="120,0,0,0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="备注与分组" Padding="12">
                    <StackPanel helpers:StackPanelHelper.Spacing="10">
                        <DockPanel>
                            <TextBlock Text="分组" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="GroupTextBox" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="备注" Width="120" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="RemarkTextBox" />
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="100" Click="BtnCancel_Click" />
            <Button x:Name="BtnSave" Content="保存" Style="{StaticResource PrimaryButtonStyle}" Width="100" Click="BtnSave_Click" />
        </StackPanel>
    </Grid>
</Window>
