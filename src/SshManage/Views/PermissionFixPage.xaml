<Page x:Class="SshManage.Views.PermissionFixPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:helpers="clr-namespace:SshManage.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="权限修复">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
            <TextBlock Text="私钥权限修复" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="一键修复Windows SSH私钥文件权限问题" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,16">
            <StackPanel helpers:StackPanelHelper.Spacing="12">
                <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                    <Button x:Name="BtnScan" Content="🔍 扫描权限问题" Style="{StaticResource PrimaryButtonStyle}" Click="BtnScan_Click" />
                    <Button x:Name="BtnFixAll" Content="🔧 一键修复全部" Style="{StaticResource SecondaryButtonStyle}" Click="BtnFixAll_Click" IsEnabled="False" />
                    <Button x:Name="BtnFixSelected" Content="修复选中" Style="{StaticResource SecondaryButtonStyle}" Click="BtnFixSelected_Click" IsEnabled="False" />
                    <Button x:Name="BtnRefresh" Content="🔄 刷新" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRefresh_Click" />
                </StackPanel>
                <TextBlock x:Name="StatusTextBlock" Text="点击扫描按钮检测私钥权限问题" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="🔐 私钥文件列表" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock x:Name="IssueCountTextBlock" Text="" FontSize="12" Foreground="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <ListView x:Name="KeyListView" 
                          Grid.Row="1" 
                          BorderThickness="0" 
                          Background="Transparent"
                          SelectionChanged="KeyListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="密钥名称" DisplayMemberBinding="{Binding Name}" Width="150" />
                            <GridViewColumn Header="类型" DisplayMemberBinding="{Binding Type}" Width="80" />
                            <GridViewColumn Header="权限状态" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PermissionStatus}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPermissionIssue}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasPermissionIssue}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="路径" DisplayMemberBinding="{Binding PrivateKeyPath}" Width="*" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
