<Page x:Class="SshManage.Views.SiteManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:helpers="clr-namespace:SshManage.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="站点管理">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
            <TextBlock Text="SSH站点管理" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="可视化管理SSH配置站点与分组" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,16">
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <Button x:Name="BtnAddSite" Content="➕ 新增站点" Style="{StaticResource PrimaryButtonStyle}" Click="BtnAddSite_Click" />
                <Button x:Name="BtnEditSite" Content="✏️ 编辑站点" Style="{StaticResource SecondaryButtonStyle}" Click="BtnEditSite_Click" IsEnabled="False" />
                <Button x:Name="BtnDeleteSite" Content="🗑️ 删除站点" Style="{StaticResource SecondaryButtonStyle}" Click="BtnDeleteSite_Click" IsEnabled="False" />
                <Button x:Name="BtnRefresh" Content="🔄 刷新" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRefresh_Click" />
                <Button x:Name="BtnSave" Content="💾 保存配置" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSave_Click" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📁 分组" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
                    <TreeView x:Name="GroupTreeView" Grid.Row="1" BorderThickness="0" Background="Transparent" SelectedItemChanged="GroupTreeView_SelectedItemChanged">
                    </TreeView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="16,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="📋 站点列表" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="SearchTextBox" Width="200" VerticalAlignment="Center" 
                                 HorizontalAlignment="Right"
                                 TextChanged="SearchTextBox_TextChanged">
                        </TextBox>
                    </DockPanel>
                    <ListView x:Name="SiteListView" 
                              Grid.Row="1" 
                              BorderThickness="0" 
                              Background="Transparent"
                              SelectionChanged="SiteListView_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="主机名" DisplayMemberBinding="{Binding Host}" Width="150" />
                                <GridViewColumn Header="地址" DisplayMemberBinding="{Binding HostName}" Width="150" />
                                <GridViewColumn Header="端口" DisplayMemberBinding="{Binding Port}" Width="60" />
                                <GridViewColumn Header="用户" DisplayMemberBinding="{Binding User}" Width="100" />
                                <GridViewColumn Header="分组" DisplayMemberBinding="{Binding GroupName}" Width="100" />
                                <GridViewColumn Header="备注" DisplayMemberBinding="{Binding Remark}" Width="*" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
